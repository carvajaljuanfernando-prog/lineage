# ── DATABASE ──────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/lineage_dev"

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="15m"

# ── APP ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# ── EMAIL (Resend) ────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Lineage <noreply@lineage.health>"

# ── STORAGE (optional, for file uploads) ─────────────────────
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
